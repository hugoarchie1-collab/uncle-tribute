{
  // -------------------------------------------------------------------------
  // TypeScript config for the Vercel serverless functions in /api.
  //
  // Every function here is SELF-CONTAINED — it imports only npm packages and
  // node: builtins, never a sibling file. That is a hard requirement, not a
  // style choice: Vercel's @vercel/node builder compiles only each function's
  // entrypoint and does NOT bundle local sibling files (e.g. a former
  // api/_lib/), so any local import crashes the function at cold start with
  // ERR_MODULE_NOT_FOUND. See CLAUDE.md gotcha #5 (verified on preview
  // 2026-05-30). This config exists mainly so `tsc -p api` type-checks the
  // functions with the right Node-ESM resolution.
  // -------------------------------------------------------------------------
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    // noEmit: `tsc -p api` is for TYPE-CHECKING ONLY. Without this it emits
    // api/*.js siblings next to the .ts sources — committed, Vercel would
    // deploy them as duplicate/shadow routes ahead of the real functions.
    "noEmit": true,
    "types": ["node"]
  },
  "include": ["**/*.ts"]
}
