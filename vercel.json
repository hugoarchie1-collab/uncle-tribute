{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "trailingSlash": false,
  "rewrites": [
    { "source": "/((?!api/|assets/|img/|video/|fonts/|logo/).*)", "destination": "/index.html" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.themandalacompany.com" }],
      "destination": "https://themandalacompany.com/:path*",
      "permanent": true
    },
    {
      "source": "/verify",
      "destination": "/auth",
      "permanent": true
    },
    {
      "source": "/stephen-meakin-biography/:path*",
      "destination": "/about",
      "permanent": true
    },
    {
      "source": "/mandala-shop/:path*",
      "destination": "/collections",
      "permanent": true
    },
    {
      "source": "/what-is-mandala/:path*",
      "destination": "/about",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "uncle-tribute.vercel.app" }],
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/img/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/video/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/logo/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
